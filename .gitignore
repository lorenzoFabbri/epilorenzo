# ── Quarto ────────────────────────────────────────────────────────────────────
/.quarto/
docs/           # rendered site output (deployed via GitHub Pages artifact)
_site/
*_cache/
*_files/
**/*.quarto_ipynb

# ── R / renv ──────────────────────────────────────────────────────────────────
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj
# renv sub-directories are covered by renv/.gitignore; repeat here for clarity
renv/library/
renv/local/
renv/cellar/
renv/staging/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
# scripts/.venv/ has its own auto-generated .gitignore (*), listed here for clarity
scripts/.venv/

# ── Credentials / secrets ─────────────────────────────────────────────────────
_hardcover_config.R
.env
.env.local

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.luarc.json
*.swp
*.swo
*~

# ── Misc build artifacts ──────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.log
node_modules/
